{
  "triggers": [
    {
      "id": "trg.beren_greets_on_arrival",
      "event": "scene.entered",
      "when": { "all_of": [ { "payload_eq": { "scene_id": "candlekeep_courtyard" } } ] },
      "do": [
        { "speak": { "text": "Old Beren steps out of the shadow of the cloister door, lantern raised. 'You'll be the Velmis girl, then. Show me the Gift, or show me your back.'" } },
        { "set_flag": { "key": "beren_intro_played", "value": true } }
      ],
      "once": true,
      "priority": 50
    },
    {
      "id": "trg.notice_sarcophagus_on_interact",
      "event": "intent.resolved",
      "when": {
        "all_of": [
          { "payload_eq": { "intent.target_id": "object.sarcophagus" } },
          { "not": { "flag_truthy": "noticed_sarcophagus" } }
        ]
      },
      "do": [
        { "set_flag": { "key": "noticed_sarcophagus", "value": true } },
        { "speak": { "text": "The flagstones underfoot tilt slightly. Half-buried beneath fresh-turned earth, a stone sarcophagus — its lid split clean in two. From inside, something dry exhales." } }
      ],
      "once": true,
      "priority": 40
    },
    {
      "id": "trg.echo_rises_on_interact",
      "event": "intent.resolved",
      "when": {
        "all_of": [
          { "payload_eq": { "intent.target_id": "object.sarcophagus" } },
          { "not": { "flag_truthy": "echo_resolved" } }
        ]
      },
      "do": [
        { "speak": { "text": "The lid grinds. A grey hand, then a face wearing your face, climbs out of the box. It opens its mouth and speaks your true name in your own voice." } },
        {
          "start_encounter": {
            "encounter_id": "encounter.hollow_echo",
            "participants": [
              { "actor_id": "morgana", "side": "players" },
              { "actor_id": "mon.hollow_echo", "side": "enemies" }
            ]
          }
        }
      ],
      "once": true,
      "priority": 30
    },
    {
      "id": "trg.open_vault_thread_on_echo_resolved",
      "event": "combat.encounter_ended",
      "when": { "all_of": [ { "payload_eq": { "encounter_id": "encounter.hollow_echo" } } ] },
      "do": [
        { "set_flag": { "key": "echo_resolved", "value": true } },
        {
          "publish_event": {
            "name": "arc.thread_opened",
            "payload": {
              "thread_id": "thread.vault_of_veiled_names",
              "summary": "Find the Vault of Veiled Names beneath Candlekeep."
            }
          }
        },
        { "speak": { "text": "The Echo collapses inward and is gone. Where it stood, a sliver of black glass — warm, finger-shaped — rests on the cracked lid. Beren is staring at you. So is Captain Vey." } }
      ],
      "once": true,
      "priority": 20
    }
  ]
}
