{
  "triggers": [
    {
      "id": "noticed_door_advance_chapter",
      "event": "combat.encounter_ended",
      "when": {
        "all_of": [
          {"flag_truthy": "noticed_door"},
          {"payload_eq": {"encounter_id": "boss"}}
        ]
      },
      "do": [
        {"set_flag": {"key": "chapter_complete", "value": true}},
        {"publish_event": {"name": "chapter.advanced"}}
      ],
      "once": true,
      "priority": 10
    }
  ]
}

