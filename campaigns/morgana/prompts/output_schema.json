{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["narration"],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0", "default": "2.0" },
    "narration": { "type": "string" },
    "spoken_dialogue": { "type": "string", "default": "" },
    "dialogue": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["npc_id", "text"],
        "properties": {
          "npc_id": { "type": "string" },
          "text": { "type": "string" },
          "tone": { "type": ["string", "null"] },
          "target": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "dice_requests": { "type": "array", "default": [] },
    "commands": { "type": "array", "default": [] },
    "state_updates": { "type": "array", "default": [] },
    "metadata": { "type": "object", "default": {} }
  }
}
