{
  "triggers": [
    {
      "id": "trg.siegfried_defeated",
      "event": "combat.encounter_ended",
      "when": { "payload_eq": { "encounter_id": "encounter.siegfrieds_storm" } },
      "do": [
        { "set_flag": { "key": "siegfried_defeated", "value": true } },
        {
          "publish_event": {
            "name": "chapter.advanced",
            "payload": {
              "chapter_id": "epilogue",
              "reason": "Siegfried stopped at Mauer Estate"
            }
          }
        },
        {
          "speak": {
            "text": "The tower's charge gutters out. Rain hammers the stone, the machinery falls silent, and for the first time since entering the estate the storm sounds like weather instead of intent."
          }
        }
      ],
      "once": true,
      "priority": 20
    }
  ]
}

